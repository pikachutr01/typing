# Sunucu portu
PORT=3001

# Çalışma ortamı: development | production
NODE_ENV=development

# Veritabanı bağlantı bilgileri
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=typing_db

# JWT imzalama secret'ı. Production'da ZORUNLUDUR; tanımlı değilse sunucu başlamaz.
# Güçlü, rastgele bir değer üretmek için örnek:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# CORS için izin verilen origin'ler, virgülle ayrılmış liste.
# Örn: https://typing.example.com,https://www.typing.example.com
# Production'da tanımlı değilse hiçbir origin'e izin verilmez.
# Development'ta tanımlı değilse tüm origin'lere izin verilir.
ALLOWED_ORIGINS=
